{
  "name": "npm-commander",
  "displayName": "npm-commander",
  "description": "",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.118.0"
  },
  "license": "MIT",
  "publisher": "Crdls",
  "repository": {
    "type": "git",
    "url": "https://github.com/Crdls/npm-commander"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:npm-commander-main"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsWelcome": [
    {
      "view": "npm-commander-main",
      "contents": "Initializing extension....",
      "when": "view == npm-commander-main"
    }
  ],
  "viewsContainers": {
    "activitybar": [
      {
        "id": "npm-commander-sidebar",
        "title": "NPM Commander",
        "icon": "media/nc-logo.svg"
      }
    ]
  },
  "views": {
    "npm-commander-sidebar": [
      {
        "id": "npm-commander-main",
        "name": "NPM Scripts"
      }
    ]
  },
  "commands": [
    { "command": "npm-commander.runNpmScript", "title": "Run", "icon": "$(play)" },
    { "command": "npm-commander.stopScript", "title": "Stop", "icon": "$(debug-stop)" },
    { "command": "npm-commander.focusTerminal", "title": "Focus" },
    { "command": "npm-commander.openPackageJson", "title": "Open package.json", "icon": "$(json)" },
    { "command": "npm-commander.refreshEntry", "title": "Refresh", "icon": "$(refresh)" },
    { "command": "npm-commander.refreshEntry-loading", "title": "Scanning...", "icon": "$(refresh~spin)" }
  ],
  "menus": {
    "view/title": [
      {
        "command": "npm-commander.refreshEntry",
        "when": "view == npm-commander-main && !npmCommanderScanning",
        "group": "navigation"
      },
      {
        "command": "npm-commander.refreshEntry-loading",
        "when": "view == npm-commander-main && npmCommanderScanning",
        "group": "navigation"
      }
    ],
    "view/item/context": [
      {
        "command": "npm-commander.runNpmScript",
        "when": "view == npm-commander-main && viewItem == script",
        "group": "inline"
      },
      {
        "command": "npm-commander.stopScript",
        "when": "view == npm-commander-main && viewItem == script-running",
        "group": "inline"
      },
      {
        "command": "npm-commander.openPackageJson",
        "when": "view == npm-commander-main && viewItem == package",
        "group": "inline"
      }
    ]
  }
}

,
  "scripts": {
    "create-package": "vsce package --no-dependencies",
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "~22.19.18",
    "@types/vscode": "^1.118.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
